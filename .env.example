# ========== APP ==========
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000

# ========== SESSION ==========
SESSION_SECRET=replace-with-a-strong-random-secret-min-64-chars

# ========== DATABASE ==========
DATABASE_PATH=./data.db

# ========== TELLABOT SMS API ==========
TELLABOT_USER=your-tellabot-email@example.com
TELLABOT_API_KEY=your-tellabot-api-key
TELLABOT_MARKUP=1.5

# ========== ADMIN SEED ==========
ADMIN_EMAIL=admin@getotps.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_USERNAME=admin

# ========== CRYPTO WALLET ADDRESSES ==========
CRYPTO_WALLET_BTC=your-btc-wallet-address
CRYPTO_WALLET_ETH=your-eth-wallet-address
CRYPTO_WALLET_USDT_TRC20=your-usdt-trc20-wallet-address
CRYPTO_WALLET_USDT_ERC20=your-usdt-erc20-wallet-address
CRYPTO_WALLET_USDC=your-usdc-wallet-address
CRYPTO_WALLET_LTC=your-ltc-wallet-address

# ========== CRYPTO RATES (USD per coin, update regularly) ==========
CRYPTO_RATE_BTC=84250.00
CRYPTO_RATE_ETH=3420.00
CRYPTO_RATE_USDT=1.00
CRYPTO_RATE_USDC=1.00
CRYPTO_RATE_LTC=92.50

# ========== TRONGRID (USDT TRC20 auto-deposit) ==========
TRONGRID_API_KEY=your-trongrid-api-key
TRON_MASTER_WALLET=your-trc20-master-wallet-address
USDT_CONTRACT_ADDRESS=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
DEPOSIT_POLL_INTERVAL_MS=30000
